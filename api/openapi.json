{
  "openapi": "3.0.0",
  "info": {
    "title": "Cyfor Workshop API",
    "version": "1.0.0",
    "description": "Workshop starter API built with Hono, Prisma, and SQLite."
  },
  "components": {
    "schemas": {
      "RootResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "openapi": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "openapi"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room A"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 500,
            "example": "Main conference room on the 2nd floor"
          },
          "type": {
            "type": "string",
            "nullable": true,
            "maxLength": 60,
            "example": "Room"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "type",
          "createdAt",
          "updatedAt"
        ]
      },
      "ItemListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "CreateItem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Main conference room on the 2nd floor"
          },
          "type": {
            "type": "string",
            "maxLength": 60,
            "example": "Room"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateItem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Conference room A"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 500,
            "example": "Main conference room on the 2nd floor"
          },
          "type": {
            "type": "string",
            "nullable": true,
            "maxLength": 60,
            "example": "Room"
          }
        }
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "itemId": {
            "type": "integer",
            "example": 1
          },
          "startAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-06-01T08:00:00.000Z"
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-06-01T10:00:00.000Z"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "Team meeting"
          },
          "notes": {
            "type": "string",
            "nullable": true,
            "maxLength": 500,
            "example": "Please set up projector"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "cancelled"
            ],
            "example": "pending"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "itemId",
          "startAt",
          "endAt",
          "purpose",
          "notes",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "ReservationListResponse": {
        "type": "object",
        "properties": {
          "reservations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reservation"
            }
          }
        },
        "required": [
          "reservations"
        ]
      },
      "CreateReservation": {
        "type": "object",
        "properties": {
          "startAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-06-01T08:00:00.000Z"
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-06-01T10:00:00.000Z"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "Team meeting"
          },
          "notes": {
            "type": "string",
            "maxLength": 500,
            "example": "Please set up projector"
          }
        },
        "required": [
          "startAt",
          "endAt",
          "purpose"
        ]
      },
      "UpdateReservation": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "cancelled"
            ],
            "example": "confirmed"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Basic API information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Conference"
            },
            "required": false,
            "name": "search",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List persisted items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Items"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItem"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a persisted item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "delete": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Remove a persisted item"
          }
        }
      },
      "patch": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateItem"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update a persisted item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "404": {
            "description": "Item not found"
          }
        }
      }
    },
    "/items/{id}/reservations": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "List reservations for an item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Item not found"
          }
        }
      },
      "post": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a reservation for an item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "400": {
            "description": "Invalid date range (end must be after start)"
          },
          "404": {
            "description": "Item not found"
          },
          "409": {
            "description": "Reservation overlaps with an existing active reservation"
          }
        }
      }
    },
    "/reservations/{id}": {
      "patch": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateReservation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update reservation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "404": {
            "description": "Reservation not found"
          },
          "409": {
            "description": "Cannot cancel an already-cancelled reservation"
          }
        }
      }
    }
  }
}
