{
  "name": "cyfor-workshop",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "generate": "npm run generate --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "sh -c 'PORT=${API_PORT:-3000} npm run dev --workspace api'",
    "dev:web": "npm run dev --workspace web",
    "dev:web:ready": "sh -c 'wait-on \"http://127.0.0.1:${API_PORT:-3000}/health\" && npm run dev:web'",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:web:ready\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^8.0.5"
  }
}
